[debug] [2026-06-07T14:28:40.977Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/intimate-hygiene/rulesets {"name":"projects/intimate-hygiene/rulesets/287b4d67-efb6-4ed1-9c92-535e39f4c598","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function isOwnerAdmin() {\n      return signedIn()\n        && (\n          request.auth.uid == \"q4VIHjWchpdb3FzB0ZKoV5zSsi83\"\n          || request.auth.token.email == \"aakashwije92@gmail.com\"\n        );\n    }\n\n    function isAdmin() {\n      return isOwnerAdmin()\n        || (\n          signedIn()\n          && exists(/databases/$(database)/documents/admins/$(request.auth.uid))\n        );\n    }\n\n    function isOrderOwner() {\n      return signedIn()\n        && (\n          resource.data.customer_id == request.auth.uid\n          || resource.data.customer_email == request.auth.token.email\n        );\n    }\n\n    match /admins/{adminId} {\n      allow read: if isAdmin();\n      allow write: if isOwnerAdmin();\n    }\n\n    match /orders/{orderId} {\n      allow create: if true;\n      allow read: if isAdmin() || isOrderOwner();\n      allow update, delete: if isAdmin();\n    }\n\n    match /customer_profiles/{profileId} {\n      allow read, write: if isAdmin() || (signedIn() && request.auth.uid == profileId);\n    }\n\n    match /products/{productId} {\n      allow read: if true;\n      allow write: if isAdmin();\n    }\n\n    match /newsletter_subscribers/{subscriberId} {\n      allow create, update: if request.resource.data.keys().hasOnly([\n        \"id\",\n        \"email\",\n        \"created_at\",\n        \"updated_at\"\n      ]) && request.resource.data.email is string;\n      allow read, delete: if isAdmin();\n    }\n\n    match /inquiries/{inquiryId} {\n      allow create: if true;\n      allow read, update, delete: if isAdmin();\n    }\n\n    match /quiz_responses/{responseId} {\n      allow create: if true;\n      allow read, update, delete: if isAdmin();\n    }\n\n    match /site_events/{eventId} {\n      allow create: if true;\n      allow read, update, delete: if isAdmin();\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-06-07T14:28:40.436431Z","metadata":{"services":["cloud.firestore"]}}
